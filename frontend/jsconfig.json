{
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./src/*"
            ],
            "@/components/*": [
                "./src/components/*"
            ],
            "@/lib/*": [
                "./src/lib/*"
            ],
            "@/types/*": [
                "./src/types/*"
            ],
            "@/hooks/*": [
                "./src/hooks/*"
            ],
            "@/context/*": [
                "./src/context/*"
            ]
        }
    },
    "include": [
        "**/*.js",
        "**/*.jsx"
    ]
}